{...}: {
  ###########################################################################
  # Immich - Image server
  ###########################################################################

  services.immich = {
    enable = true;
    host = "0.0.0.0";
    port = 2283;
    mediaLocation = "/var/lib/immich";
  };

  ###########################################################################
  # Opens Firewall ports - Immich
  ###########################################################################

  networking.firewall.allowedTCPPorts = [2283];
}
